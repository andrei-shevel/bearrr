# Local machine — used by deploy.sh
HOST=root@YOUR_SERVER_IP
REMOTE=/home/nextjs/bearrr
RUN_USER=nextjs

# Server ($REMOTE/.env) — used by docker compose at build & run time
SITE_URL=https://bearrr.io
PORT=3000
# Mixpanel (optional — analytics disabled when unset)
NEXT_PUBLIC_MIXPANEL_TOKEN=
# Use https://api-eu.mixpanel.com for EU data residency
NEXT_PUBLIC_MIXPANEL_API_HOST=https://api-eu.mixpanel.com
